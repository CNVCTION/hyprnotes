{
  "name": "hyprnotes",
  "version": "1.0.1",
  "description": "Dead-simple CLI notepad with minimalist TUI — type, slash commands, save/load. No AI, no modes, just notes.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hyprnotes": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "echo \"No tests defined\" && exit 0",
    "prepare": "test -d src && npm run build || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "notes",
    "cli",
    "tui",
    "notepad",
    "terminal"
  ],
  "author": "cnvction.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cnvction/hyprnotes.git"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.0",
    "chalk": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
